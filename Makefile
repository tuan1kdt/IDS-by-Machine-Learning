# Makefile for building the IDS-by-ML final report (LLNCS / Springer LNCS).
#
# Usage:
#   make            # build main.pdf (runs pdflatex twice to resolve refs)
#   make quick      # build main.pdf with a single pdflatex pass (faster, refs may be stale)
#   make view       # open main.pdf in the default viewer (macOS / Linux)
#   make clean      # remove LaTeX auxiliary files (.aux .log .out .toc ...)
#   make distclean  # clean + remove main.pdf
#
# Requires a TeX Live installation with the following collections:
#   - texlive-latex-base / texlive-latex-recommended / texlive-latex-extra
#   - texlive-fonts-recommended
#   - texlive-pictures (tikz, pgfplots)
#   - texlive-science  (algorithm, algpseudocode)         <-- "collection-mathscience" via tlmgr
#
# The LLNCS class file (llncs.cls) and the splncs04 bibliography style
# (splncs04.bst) are shipped inside this folder, so no extra setup is
# required beyond a working pdflatex binary.

# --- Configurable knobs ---------------------------------------------------
LATEX       ?= pdflatex
LATEXFLAGS  ?= -interaction=nonstopmode -halt-on-error
MAIN         = main
SECTIONS     = 1 2 3 4
SRC          = $(MAIN).tex \
               $(foreach s,$(SECTIONS),$(wildcard $(s)/*.tex)) \
               llncs.cls splncs04.bst

# --- Default target -------------------------------------------------------
.PHONY: all
all: $(MAIN).pdf

# Two pdflatex passes are needed to resolve \ref / \cite / \label references.
$(MAIN).pdf: $(SRC)
	$(LATEX) $(LATEXFLAGS) $(MAIN).tex
	$(LATEX) $(LATEXFLAGS) $(MAIN).tex
	@echo ""
	@echo "--> Built $(MAIN).pdf ($$(pdfinfo $(MAIN).pdf 2>/dev/null | awk '/^Pages:/ {print $$2" pages"}'))"

# --- Fast single-pass build (cross-references may be stale) ---------------
.PHONY: quick
quick:
	$(LATEX) $(LATEXFLAGS) $(MAIN).tex

# --- View the compiled PDF ------------------------------------------------
.PHONY: view
view: $(MAIN).pdf
	@if command -v open >/dev/null 2>&1; then \
	    open $(MAIN).pdf; \
	elif command -v xdg-open >/dev/null 2>&1; then \
	    xdg-open $(MAIN).pdf; \
	else \
	    echo "No PDF viewer found. Open $(MAIN).pdf manually."; \
	fi

# --- Clean targets --------------------------------------------------------
# Aux extensions generated by pdflatex / biblatex / hyperref / listings.
AUX_EXT = aux log out toc lof lot bbl blg nav snm vrb fls fdb_latexmk synctex.gz

.PHONY: clean
clean:
	@for ext in $(AUX_EXT); do \
	    find . -type f -name "*.$$ext" -delete; \
	done
	@echo "--> Cleaned LaTeX auxiliary files."

.PHONY: distclean
distclean: clean
	@rm -f $(MAIN).pdf
	@echo "--> Removed $(MAIN).pdf."

# --- Help -----------------------------------------------------------------
.PHONY: help
help:
	@echo "Targets:"
	@echo "  all        build main.pdf (default)"
	@echo "  quick      single-pass build (fast, refs may be stale)"
	@echo "  view       open main.pdf in the default viewer"
	@echo "  clean      remove LaTeX aux files"
	@echo "  distclean  clean + remove main.pdf"
	@echo "  help       this message"
